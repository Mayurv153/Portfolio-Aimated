<head>
<style>
  body { font-family: 'Segoe UI', Arial, sans-serif; margin: 40px; color: #1a1a2e; line-height: 1.6; }
  h1 { font-size: 28px; margin-bottom: 2px; color: #0f0f23; }
  h2 { font-size: 16px; color: #555; border-bottom: 2px solid #0f0f23; padding-bottom: 4px; margin-top: 24px; }
  .subtitle { font-size: 14px; color: #666; margin-bottom: 4px; }
  .contact { font-size: 12px; color: #444; margin-bottom: 20px; }
  .contact a { color: #2563eb; text-decoration: none; }
  .section { margin-bottom: 16px; }
  .entry { margin-bottom: 12px; }
  .entry-header { display: flex; justify-content: space-between; align-items: baseline; }
  .entry-title { font-weight: bold; font-size: 14px; }
  .entry-date { font-size: 12px; color: #666; }
  .entry-sub { font-size: 13px; color: #555; font-style: italic; }
  ul { margin: 4px 0; padding-left: 20px; }
  li { font-size: 13px; margin-bottom: 2px; }
  .skills-grid { display: flex; flex-wrap: wrap; gap: 6px; }
  .skill-tag { background: #f0f0f0; padding: 3px 10px; border-radius: 4px; font-size: 12px; }
</style>
